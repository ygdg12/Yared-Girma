{
  "name": "yared-portfolio-deploy",
  "private": true,
  "workspaces": [
    "yared-portfolio"
  ],
  "scripts": {
    "build": "npm run build --workspace yared-portfolio && node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});fs.cpSync('yared-portfolio/dist','dist',{recursive:true});\""
  }
}
